# ==========================================
# PulseScope — Git Ignore
# ==========================================

# --- Dependencies ---
node_modules/

# --- Secrets ---
.env
*.pem
*.key

# --- Build outputs ---
dist/
build/
*.tsbuildinfo

# --- Database (SQLite) ---
*.db
*.db-journal
*.db-wal
*.db-shm

# --- IDE / Editor ---
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- OS ---
.DS_Store
Thumbs.db

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Temp / Test artifacts ---
*.tmp
*.temp
screenshot*.png

# --- Vite cache ---
.vite/
