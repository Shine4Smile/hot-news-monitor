# ==================================
# PulseScope — 环境变量配置模板
# ==================================
# 复制此文件为 .env 并填入真实值
# 注意: .env 文件不会被提交到 Git

# DeepSeek API Key (必填 - 用于 AI 内容验证和热点发现)
# 获取地址: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 服务器端口 (可选, 默认 3000)
PORT=3000

# 热点采集间隔 (可选, 单位: 分钟, 默认 5)
COLLECT_INTERVAL_MINUTES=5

# AI 验证间隔 (可选, 单位: 分钟, 默认 10)
VERIFY_INTERVAL_MINUTES=10
